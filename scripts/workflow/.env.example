# SmithFit Workflow — Environment Variables
# Copy this file to .env and fill in your values.
# Never share or commit the .env file.

# ── Anthropic (Claude) ────────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend ────────────────────────────────────────────────────────
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Your sending email address (must be verified in Resend)
FROM_EMAIL=SmithFit <hello@smithfit.online>
REPLY_TO_EMAIL=hello@smithfit.online

# ── GoHighLevel (GHL) ─────────────────────────────────────────────
# API Token: GHL → Settings → API Keys (starts with pit-)
GHL_API_KEY=pit-...
# Location ID: GHL → Settings → Business Profile → Location ID
GHL_LOCATION_ID=TSWnCFvIE58IDjlDc4Ym
